# ── Kids Learning App - Staging Environment ──────────────────────────────────
# Pre-production environment for QA and release validation.
# Mirrors production configuration at reduced scale.
# Secrets are injected via AWS Secrets Manager at deploy time.
# ──────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=staging
PORT=4000
CORS_ORIGIN=https://staging.kidslearningfun.app
APP_VERSION=${DEPLOY_VERSION:-staging}

# Database (RDS - connection string from Secrets Manager)
# DATABASE_URL=<injected from AWS Secrets Manager>

# Redis (ElastiCache - connection string from Secrets Manager)
# REDIS_URL=<injected from AWS Secrets Manager>

# Auth
JWT_EXPIRES_IN=7d
# JWT_SECRET=<injected from AWS Secrets Manager>

# Storage (S3)
STORAGE_PROVIDER=s3
STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=<set by Terraform output>

# Media Processing
SHARP_CONCURRENCY=4
MAX_UPLOAD_SIZE_MB=100

# Workers
WORKER_MEDIA_CONCURRENCY=4
WORKER_AI_CONCURRENCY=2

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_MAINTENANCE_MODE=false
