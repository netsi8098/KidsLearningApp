# ── Kids Learning App - Local Development ─────────────────────────────────────
# Non-secret configuration for local development.
# Copy to backend/.env and fill in secrets (JWT_SECRET, etc.)
# ──────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
APP_VERSION=local

# Database (local PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kids_learning_dev

# Redis (local)
REDIS_URL=redis://localhost:6379

# Auth
JWT_EXPIRES_IN=7d
# JWT_SECRET=<set locally, min 16 chars>

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads

# Media Processing
SHARP_CONCURRENCY=2
MAX_UPLOAD_SIZE_MB=50

# Workers
WORKER_MEDIA_CONCURRENCY=2
WORKER_AI_CONCURRENCY=1

# Rate Limiting (generous for dev)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=1000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=pretty

# Feature Flags
ENABLE_MAINTENANCE_MODE=false
