# ============================================================================
# Kids Learning Backend - Environment Variables
# ============================================================================
# Copy this file to `.env` and fill in the values for your environment.
# For local development, you can also use `.env.development` which ships
# with safe defaults (no real secrets).
#
# NEVER commit `.env` or `.env.production` to version control.
# ============================================================================

# ── Server ──────────────────────────────────────────────────────────────────

# Port the Express server listens on
PORT=4000

# Runtime environment: development | test | staging | production
NODE_ENV="development"

# Allowed CORS origin (frontend URL)
CORS_ORIGIN="http://localhost:5173"

# ── Database ────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kids_learning"

# ── Redis ───────────────────────────────────────────────────────────────────

# Redis connection string (used by BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# ── Authentication ──────────────────────────────────────────────────────────

# Secret key for signing JWTs (min 16 chars; use 32+ chars in production)
JWT_SECRET="change-me-in-production"

# JWT token lifetime (e.g. "7d", "24h", "30m")
JWT_EXPIRES_IN="7d"

# Optional: set during JWT secret rotation to keep old tokens valid
# JWT_SECRET_PREVIOUS=""

# ── Object Storage ─────────────────────────────────────────────────────────

# Storage backend: "local" (disk) or "s3" (S3-compatible)
STORAGE_PROVIDER="local"

# Path for local file storage (relative to project root)
STORAGE_LOCAL_PATH="./uploads"

# S3 configuration (required when STORAGE_PROVIDER=s3)
STORAGE_S3_BUCKET=""
STORAGE_S3_REGION=""
STORAGE_S3_ACCESS_KEY=""
STORAGE_S3_SECRET_KEY=""
# Optional: custom S3 endpoint (for MinIO, DigitalOcean Spaces, etc.)
STORAGE_S3_ENDPOINT=""

# ── Media Processing ───────────────────────────────────────────────────────

# Number of concurrent Sharp (image processing) threads (1-8)
SHARP_CONCURRENCY=2

# Maximum upload file size in megabytes (1-500)
MAX_UPLOAD_SIZE_MB=50

# ── AI Services ────────────────────────────────────────────────────────────
# Used for brief generator, story pipeline, illustration generation

# OpenAI API key (optional -- features degrade gracefully without it)
OPENAI_API_KEY=""

# Anthropic API key (optional -- features degrade gracefully without it)
ANTHROPIC_API_KEY=""

# ── Worker Settings ────────────────────────────────────────────────────────

# Max concurrent media processing jobs
WORKER_MEDIA_CONCURRENCY=2

# Max concurrent AI generation jobs
WORKER_AI_CONCURRENCY=1

# ── Rate Limiting ──────────────────────────────────────────────────────────

# Time window in milliseconds for rate limiting
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window per IP
RATE_LIMIT_MAX=200

# ── Feature Flags ──────────────────────────────────────────────────────────

# Set to "true" to enable maintenance mode (returns 503 for all API routes)
ENABLE_MAINTENANCE_MODE=false

# ── Logging ────────────────────────────────────────────────────────────────

# Log level: debug | info | warn | error
LOG_LEVEL="info"

# Log format: "pretty" for development, "json" for production
LOG_FORMAT="pretty"
