# ============================================================================
# Kids Learning Backend - Test Environment
# ============================================================================
# Used by `vitest` and CI test runs. Safe to commit.
# Uses a separate database and Redis DB index to avoid conflicts.
# ============================================================================

NODE_ENV=test
PORT=4001

DATABASE_URL=postgresql://test:test@localhost:5432/kids_learning_test
REDIS_URL=redis://localhost:6379/1

JWT_SECRET=test-secret-key-for-testing-only
JWT_EXPIRES_IN=1h

STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads-test

CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=error
LOG_FORMAT=pretty
