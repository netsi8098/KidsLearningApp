# ── Kids Learning App - Development Environment ──────────────────────────────
# Shared dev environment for CI and team testing.
# Secrets are injected via AWS Secrets Manager at deploy time.
# ──────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=https://dev.kidslearningfun.app
APP_VERSION=${DEPLOY_VERSION:-dev}

# Database (RDS - connection string from Secrets Manager)
# DATABASE_URL=<injected from AWS Secrets Manager>

# Redis (ElastiCache - connection string from Secrets Manager)
# REDIS_URL=<injected from AWS Secrets Manager>

# Auth
JWT_EXPIRES_IN=7d
# JWT_SECRET=<injected from AWS Secrets Manager>

# Storage (S3)
STORAGE_PROVIDER=s3
STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=<set by Terraform output>
# STORAGE_S3_ACCESS_KEY=<injected from AWS Secrets Manager or use IAM role>

# Media Processing
SHARP_CONCURRENCY=2
MAX_UPLOAD_SIZE_MB=50

# Workers
WORKER_MEDIA_CONCURRENCY=2
WORKER_AI_CONCURRENCY=1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=500

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Feature Flags
ENABLE_MAINTENANCE_MODE=false
