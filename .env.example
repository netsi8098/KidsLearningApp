# ============================================================================
# Kids Learning Fun (Frontend PWA) - Environment Variables
# ============================================================================
# Vite exposes only variables prefixed with VITE_ to the client bundle.
# NEVER put secrets here -- everything is embedded in the JavaScript bundle.
#
# Copy this file to `.env` or `.env.local` for local overrides.
# ============================================================================

# ── API ────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:4000

# ── App Metadata ───────────────────────────────────────────────────────────

# Application name displayed in UI chrome
VITE_APP_NAME="Kids Learning Fun"

# Current app version (injected at build time in CI)
VITE_APP_VERSION=0.0.0-dev

# ── Feature Flags ──────────────────────────────────────────────────────────

# Enable analytics event collection (true | false)
VITE_ENABLE_ANALYTICS=false

# Enable debug overlays and dev tools (true | false)
VITE_ENABLE_DEBUG=false

# ── Third Party ────────────────────────────────────────────────────────────

# Sentry DSN for error reporting (leave empty to disable)
VITE_SENTRY_DSN=
