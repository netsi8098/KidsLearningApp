# ── Kids Learning App - Production Environment ───────────────────────────────
# Live production configuration.
# ALL secrets are injected via AWS Secrets Manager. Never store secrets here.
# ──────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=production
PORT=4000
CORS_ORIGIN=https://kidslearningfun.app
APP_VERSION=${DEPLOY_VERSION}

# Database (RDS Multi-AZ - connection string from Secrets Manager)
# DATABASE_URL=<injected from AWS Secrets Manager>

# Redis (ElastiCache Multi-AZ - connection string from Secrets Manager)
# REDIS_URL=<injected from AWS Secrets Manager>

# Auth
JWT_EXPIRES_IN=7d
# JWT_SECRET=<injected from AWS Secrets Manager, min 32 chars>

# Storage (S3)
STORAGE_PROVIDER=s3
STORAGE_S3_REGION=us-east-1
# STORAGE_S3_BUCKET=<set by Terraform output>

# Media Processing
SHARP_CONCURRENCY=4
MAX_UPLOAD_SIZE_MB=100

# Workers
WORKER_MEDIA_CONCURRENCY=4
WORKER_AI_CONCURRENCY=2

# Rate Limiting (strict for production)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# Logging (JSON only in production for log aggregation)
LOG_LEVEL=info
LOG_FORMAT=json

# Feature Flags
ENABLE_MAINTENANCE_MODE=false
