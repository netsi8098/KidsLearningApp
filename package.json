{
  "name": "kidslearningapp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:child": "npx playwright test --config=e2e/playwright.config.ts --project=child-mobile --project=child-tablet",
    "test:e2e:parent": "npx playwright test --config=e2e/playwright.config.ts --project=parent-mobile --project=parent-desktop",
    "test:e2e:admin": "npx playwright test --config=e2e/playwright.config.ts --project=admin-desktop",
    "test:all": "npm run test && npm run test:backend && npm run test:admin",
    "test:backend": "cd backend && npx vitest run",
    "test:admin": "cd admin && npx vitest run",
    "test:ci": "npm run test -- --reporter=junit --outputFile=coverage/frontend-results.xml && npm run test:backend && npm run test:admin",
    "test:certify": "npm run test:all && npm run test:e2e"
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "vite-plugin-pwa": "^1.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.2"
  }
}
